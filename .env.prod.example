# Dupli1 production environment (single EC2)
# Copy to .env.prod and fill in strong secrets. Never commit .env.prod.

POSTGRES_PASSWORD=change-me-strong-postgres-password
JWT_SECRET=change-me-strong-jwt-secret

OWNER_EMAIL=admin@dupli1.com
OWNER_PASSWORD=change-me-owner-password

DUPLI1_WEB_SERVICE_EMAIL=dupli1-web@service.dupli1.com
DUPLI1_WEB_SERVICE_PASSWORD=change-me-web-service-password
DUPLI1_ORDER_SERVICE_EMAIL=dupli1-order@service.dupli1.com
DUPLI1_ORDER_SERVICE_PASSWORD=change-me-order-service-password

MINIO_ACCESS_KEY=dupli1
MINIO_SECRET_KEY=change-me-minio-secret

# Public origin of the nginx gateway (api/nginx.prod.conf) — used to build
# browser-facing product image URLs, since MinIO itself isn't exposed.
S3_PUBLIC_ENDPOINT=https://your-domain.example

TELEGRAM_BOT_TOKEN=
TELEGRAM_ORDER_CHAT_ID=
TELEGRAM_PRODUCT_CHAT_ID=
