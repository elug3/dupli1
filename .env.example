# Schick local / staging environment
# Copy to .env and adjust as needed.

# Shared
JWT_SECRET=dev-secret-change-in-production

# Auth (schick-auth)
DB_URL=postgres://schick:schick_dev@localhost:5432/schick_db?sslmode=disable
OWNER_EMAIL=admin@schick.com
OWNER_PASSWORD=password

# Product (schick-product)
SCHICK_PRODUCT_DB=postgres://schick:schick_dev@localhost:5433/products?sslmode=disable
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=schick
S3_SECRET_KEY=schick_dev
S3_BUCKET=product-images

# MinIO
MINIO_ACCESS_KEY=schick
MINIO_SECRET_KEY=schick_dev

# Production RDS example (do not commit real passwords)
# DB_URL=postgres://schick:<password>@schick-production.xxxxx.us-east-1.rds.amazonaws.com:5432/schick_db?sslmode=require
# SCHICK_PRODUCT_DB=postgres://schick:<password>@schick-production.xxxxx.us-east-1.rds.amazonaws.com:5432/products?sslmode=require
