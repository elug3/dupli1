# Schick local / staging environment
# Copy to .env and adjust as needed.

# Shared
JWT_SECRET=dev-secret-change-in-production

# Auth (schick-auth) — local Docker Postgres by default
DB_URL=postgres://schick:schick_dev@localhost:5432/schick_db?sslmode=disable
OWNER_EMAIL=admin@schick.com
OWNER_PASSWORD=password
SCHICK_WEB_SERVICE_EMAIL=schick-web@internal.schick
SCHICK_WEB_SERVICE_PASSWORD=change-me-in-production

# Product (schick-product) — local Docker Postgres by default
SCHICK_PRODUCT_DB=postgres://schick:schick_dev@localhost:5433/products?sslmode=disable
AUTH_JWKS_URL=http://localhost:18080/api/v1/auth/.well-known/jwks.json
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=schick
S3_SECRET_KEY=schick_dev
S3_BUCKET=product-images

# MinIO
MINIO_ACCESS_KEY=schick
MINIO_SECRET_KEY=schick_dev

# Notification (schick-notification) — Telegram bot for manager alerts
NATS_URL=nats://localhost:4222
TELEGRAM_BOT_TOKEN=
TELEGRAM_ORDER_CHAT_ID=
TELEGRAM_PRODUCT_CHAT_ID=

# Amazon RDS (production) — use fetch-rds-env.sh instead of editing manually
# bash infra/scripts/fetch-rds-env.sh   # writes .env.rds from Secrets Manager
# docker compose -f docker-compose.yml -f docker-compose.rds.yml --env-file .env.rds up
