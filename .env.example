# Dupli1 local / staging environment
# Copy to .env and adjust as needed.

# Shared
JWT_SECRET=dev-secret-change-in-production

# Auth (dupli1-auth) — local Docker Postgres by default
DB_URL=postgres://dupli1:dupli1_dev@localhost:5432/dupli1_db?sslmode=disable
OWNER_EMAIL=admin@dupli1.com
OWNER_PASSWORD=password
DUPLI1_WEB_SERVICE_EMAIL=dupli1-web@internal.dupli1
DUPLI1_WEB_SERVICE_PASSWORD=change-me-in-production
DUPLI1_ORDER_SERVICE_EMAIL=dupli1-order@internal.dupli1
DUPLI1_ORDER_SERVICE_PASSWORD=change-me-in-production

# Product (dupli1-product) — local Docker Postgres by default
DUPLI1_PRODUCT_DB=postgres://dupli1:dupli1_dev@localhost:5433/products?sslmode=disable
AUTH_JWKS_URL=http://localhost:18080/api/v1/auth/.well-known/jwks.json
# Guest PDP views: leave Secure unset/false for local HTTP; production ECS sets GUEST_COOKIE_SECURE=true
# GUEST_COOKIE_SECURE=false
# PRODUCT_VIEWS_ENABLED=true
S3_ENDPOINT=http://localhost:9000
# Browser-facing base for imageUrls (Upload appends /{objectKey} only).
# Compose gateway: http://localhost:8080/product-images
# AWS CloudFront: https://images.dupli1.com
# S3_PUBLIC_ENDPOINT=http://localhost:8080/product-images
S3_ACCESS_KEY=dupli1
S3_SECRET_KEY=dupli1_dev
S3_BUCKET=product-images

# Order (dupli1-order) — local Docker Postgres by default
DUPLI1_ORDER_DB=postgres://dupli1:dupli1_dev@localhost:5435/orders?sslmode=disable
DUPLI1_AUTH_URL=http://localhost:18080
DUPLI1_GATEWAY_URL=http://localhost:8080
# Deprecated direct product override (prefer DUPLI1_GATEWAY_URL):
# DUPLI1_PRODUCT_URL=http://localhost:8081
# Optional static override for product stock calls (otherwise login via DUPLI1_ORDER_SERVICE_*):
# DUPLI1_ORDER_STOCK_BEARER_TOKEN=

# MinIO
MINIO_ACCESS_KEY=dupli1
MINIO_SECRET_KEY=dupli1_dev

# Notification (dupli1-notification) — Telegram bot for manager alerts
NATS_URL=nats://localhost:4222
TELEGRAM_BOT_TOKEN=
TELEGRAM_ORDER_CHAT_ID=
TELEGRAM_PRODUCT_CHAT_ID=

# Amazon RDS (production) — use fetch-rds-env.sh instead of editing manually
# bash infra/scripts/fetch-rds-env.sh   # writes .env.rds from Secrets Manager
# docker compose -f docker-compose.yml -f docker-compose.rds.yml --env-file .env.rds up
