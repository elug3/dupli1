aws_region                 = "us-east-1"
project_name               = "dupli1"
environment                = "production"
vpc_id                     = "vpc-0e143b53ca2a4714c"
public_subnet_ids          = ["subnet-0d757c4cf8d71963b", "subnet-02c1003124987322c"]
private_subnet_ids         = ["subnet-01fd0882721f10499", "subnet-006b8428713711816"]
ecs_cluster_name           = "production"
service_discovery_namespace_id = "ns-5d53uocv3zvhmgrz"
rds_security_group_id      = "sg-073c0d32fa81e03e6"
rds_instance_identifier    = "dupli1-production"
ecs_instance_type          = "t3.large"
# Trunking is enabled on ECS instances — 2 hosts pack all 11 services.
ecs_asg_desired_capacity   = 2
ecs_asg_min_size           = 1
ecs_asg_max_size           = 4
desired_count              = 1
image_tag                  = "latest"

# Product images CDN (CloudFront + OAC). Requires ACM SAN or *.dupli1.com.
# product_images_cdn_aliases = ["images.dupli1.com"]
# product_images_cdn_aliases = []  # use *.cloudfront.net only
